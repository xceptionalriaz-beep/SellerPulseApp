# ============================================
# RIAZIFY — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://ohgejewwsnbyouozymcc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Riazify

# --- In production (Vercel), set NEXT_PUBLIC_APP_URL to your domain ---
# NEXT_PUBLIC_APP_URL=https://riazify.com
